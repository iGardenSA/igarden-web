# ==========================================================================
# iGarden Web — Environment Variables
# انسخ هذا الملف إلى .env.local وعبّئ القيم
# ==========================================================================

# ----- الموقع -----
NEXT_PUBLIC_SITE_URL=https://igarden.sa
NEXT_PUBLIC_SHOP_URL=https://shop.igarden.sa

# ----- Sanity CMS -----
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- التحليلات (اختياري) -----
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=igarden.sa
# أو Google Analytics
# NEXT_PUBLIC_GA_ID=

# ----- الإيميل (للنماذج) -----
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@igarden.sa
